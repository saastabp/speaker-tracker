# ─────────────────────────────────────────────────────────────
# speaker-tracker — Python (backend) + Node/Vite (frontend) + CDK (infra)
# Purpose-built. Do NOT reintroduce the virtualenv [Bb]in/[Ll]ib patterns:
# they silently ignore infra/cdk/bin/*.ts and infra/cdk/lib/*.ts.
# ─────────────────────────────────────────────────────────────

# ── Python (backend) ──
__pycache__/
*.py[cod]
*.so
.venv/
venv/
*.egg-info/
.eggs/
build/
dist/
# tooling caches
.ruff_cache/
.pytest_cache/
.mypy_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
# NOTE: uv.lock and rds-ca-bundle.pem ARE committed — not ignored.

# ── Node / frontend ──
node_modules/
frontend/dist/

# ── Environment files ──
# Committed per-mode build config (.env.production, .env.sandbox) is intentional —
# Cognito client IDs are public. Only secrets/local overrides are ignored.
.env
.env.local
.env.*.local

# ── CDK / infra ──
cdk.out/
infra/**/cdk.out/
infra/**/*.js
infra/**/*.d.ts

# ── IDE / editor ──
.idea/
*.iml
.DS_Store

# ── Claude Code ──
.claude/settings.local.json